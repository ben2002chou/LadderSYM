# Dataset roots and split metadata
export LADDERSYM_COCO_ROOT=/absolute/path/to/CocoChorales-E
export LADDERSYM_COCO_SPLIT_JSON=$LADDERSYM_COCO_ROOT/split.json

export LADDERSYM_MAESTRO_ROOT=/absolute/path/to/MAESTRO-E
export LADDERSYM_MAESTRO_SPLIT_JSON=$LADDERSYM_MAESTRO_ROOT/maestro-v3.0.0.json

# Optional local cache for Coco file path indexing (do not publish this file).
# If unset, cache defaults to Hydra run output dir.
export LADDERSYM_COCO_FILE_PATH_CACHE=$PWD/.cache/laddersym/coco_file_paths_cache.json

# Optional warm-start checkpoint for MAESTRO training
export LADDERSYM_MAESTRO_PRETRAINED_CKPT=/absolute/path/to/coco_prompted_model.ckpt
